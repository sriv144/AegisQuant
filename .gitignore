.env
.venv/
__pycache__/
.pytest_cache/
*.pyc
alert_history.jsonl
trading_history.jsonl
*.db
*.sqlite
*.sqlite3

# Stray artifacts: pip-stderr redirects (files literally named "=X.Y.Z" created
# by running `pip install pkg =1.2.3` instead of `pip install "pkg>=1.2.3"`),
# and captured stdout/stderr logs that should never be committed.
=*
*.log
run_log.txt
pytest_*.txt
