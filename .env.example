# AegisQuant Environment Configuration
# Copy this file to `.env` and fill in the values below.

# 1. Execution & Broker (Alpaca)
ALPACA_API_KEY="your_alpaca_api_key"
ALPACA_SECRET_KEY="your_alpaca_secret_key"

# 2. LLM / Alternative Data
# OPENAI_API_KEY powers the current LangChain agent workflow.
# ANTHROPIC_API_KEY is reserved for future LLM-backed flows.
OPENAI_API_KEY="your_openai_api_key"
ANTHROPIC_API_KEY="your_anthropic_api_key"
NEWSAPI_KEY="your_newsapi_key"

# 3. Data and messaging mode
# True = offline-friendly mock data, False = live yfinance/Redis behavior.
ENABLE_MOCK_DATA="True"
REDIS_URL="redis://localhost:6379/0"

# 4. Alerting & thresholds
SLACK_WEBHOOK_URL=""
MAX_DRAWDOWN_THRESHOLD=0.15
MIN_SHARPE_THRESHOLD=0.0

# 5. Email fallback
ALERT_EMAIL="you@example.com"
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your_sendgrid_api_key"

# 6. Database connectivity
# Defaults to local SQLite if left commented.
# POSTGRES_URL="postgresql://user:password@localhost:5432/aegisquant"
