# AegisQuant Environment Configuration
# Copy this file to `.env` and fill in the values below.

# ── Market Selection ─────────────────────────────────────────────────────────
# "US" for US markets (Alpaca, S&P 500, USD, ET timezone)
# "IN" for Indian markets (Zerodha/AngelOne, NSE, INR, IST timezone)
MARKET="US"
BENCHMARK_SYMBOL="SPY"

# ── Broker Selection ─────────────────────────────────────────────────────────
# "alpaca" = Alpaca (US), "zerodha" = Zerodha (India), "angelone" = Angel One (India), "paper" = simulation
BROKER="alpaca"
INITIAL_CAPITAL="100000"

# 1. Alpaca (US Markets)
ALPACA_API_KEY="your_alpaca_api_key"
ALPACA_SECRET_KEY="your_alpaca_secret_key"
ALPACA_BASE_URL="https://paper-api.alpaca.markets"

# 2. Zerodha (India) — uncomment if using
# KITE_API_KEY="your_kite_api_key"
# KITE_API_SECRET="your_kite_api_secret"
# KITE_ACCESS_TOKEN=""

# 3. Angel One (India) — uncomment if using
# ANGEL_API_KEY="your_angel_api_key"
# ANGEL_CLIENT_ID="your_client_id"
# ANGEL_PASSWORD="your_password"
# ANGEL_TOTP_SECRET="your_totp_secret"

# 2. LLM / Alternative Data
# OPENAI_API_KEY powers the current LangChain agent workflow.
# OpenRouter keys starting with sk-or-v1 are auto-routed to OpenRouter.
# ANTHROPIC_API_KEY is reserved for future LLM-backed flows.
OPENAI_API_KEY="your_openai_api_key"
ENABLE_LLM_AGENTS="True"
LLM_MODEL=""
ANTHROPIC_API_KEY="your_anthropic_api_key"
NEWSAPI_KEY="your_newsapi_key"

# 3. Data and messaging mode
# True = offline-friendly mock data, False = live yfinance/Redis behavior.
ENABLE_MOCK_DATA="True"
REDIS_URL="redis://localhost:6379/0"

# Broker execution safety
# Keep False for local development to avoid placing broker orders.
ENABLE_BROKER_EXECUTION="False"

# US v2 sleeve rollout
# KILL_SWITCH=true always forces dry-run. V2_LIVE_START_DATE prevents live
# orders before the configured New York trading date.
KILL_SWITCH="true"
ENABLED_SLEEVES="xs_momentum,value_quality_momentum"
UNIVERSE="sp100"
V2_LIVE_START_DATE="2026-06-08"
V2_MAX_TOTAL_INVESTED="0.65"
V2_MAX_SLEEVE_NAV="0.325"
V2_MAX_POSITION_NAV="0.05"
V2_MAX_SECTOR_NAV="0.20"
V2_BETA_MIN="0.0"
V2_BETA_MAX="1.0"
V2_ENFORCE_BETA="true"
V2_MIN_TRADE_NAV_PCT="0.005"
V2_REQUIRE_PRETRADE_REVIEW="false"
DECISION_INTERVAL_MINUTES="30"
WEEKLY_LOSS_STOP="0.02"
ENABLE_LIVE_PROMOTION="false"

# 4. Alerting & thresholds
SLACK_WEBHOOK_URL=""
MAX_DRAWDOWN_THRESHOLD=0.15
MIN_SHARPE_THRESHOLD=0.0

# 5. Email fallback
ALERT_EMAIL="you@example.com"
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="your_sendgrid_api_key"

# 6. Dashboard Auth
# Set a password to enable JWT authentication on the web dashboard
# Leave empty for open access (dev mode)
AEGIS_PASSWORD=""

# 7. Database connectivity
# Defaults to local SQLite if left commented.
# POSTGRES_URL="postgresql://user:password@localhost:5432/aegisquant"

# 7. Dashboard API authentication
# Required by /api/* routes. If unset, the server prints a generated key at startup.
AEGIS_API_KEY=""
